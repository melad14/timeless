{
  "info": {
    "name": "Timeless API — Frontend",
    "description": "مجموعة طلبات لربط الفرونت إند بخادم Timeless (FastAPI).\n\nبعد Login أو Signup انسخ access_token إلى المتغير accessToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "accessToken", "value": "" },
    { "key": "capsuleId", "value": "1" },
    { "key": "userId", "value": "1" }
  ],
  "item": [
    {
      "name": "Root & Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"password12\",\n  \"phone_number\": \"+966500000000\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/signup"
          }
        },
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password12\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /users/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "PUT /users/me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_username\",\n  \"phone_number\": \"+966511111111\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "DELETE /users/me",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "GET /users/{user_id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Time capsules",
      "item": [
        {
          "name": "POST create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"كبسولة تجريبية\",\n  \"content\": \"محتوى نصي يُرسل صافياً؛ الخادم يشفّره.\",\n  \"content_type\": \"text\",\n  \"open_date\": \"2027-06-01T12:00:00Z\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/time-capsules"
          }
        },
        {
          "name": "GET list mine",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules?skip=0&limit=50"
          }
        },
        {
          "name": "GET pending",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules/pending?skip=0&limit=50"
          }
        },
        {
          "name": "GET opened",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules/opened?skip=0&limit=50"
          }
        },
        {
          "name": "GET by id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules/{{capsuleId}}"
          }
        },
        {
          "name": "PUT update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"عنوان محدّث\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/time-capsules/{{capsuleId}}"
          }
        },
        {
          "name": "POST open",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules/{{capsuleId}}/open"
          }
        },
        {
          "name": "DELETE",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/time-capsules/{{capsuleId}}"
          }
        },
        {
          "name": "POST check-ready (cron)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1/time-capsules/check-ready"
          }
        }
      ]
    }
  ]
}
