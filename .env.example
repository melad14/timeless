# ============================================================================
# TIMELESS MESSAGING BACKEND - ENVIRONMENT CONFIGURATION
# ============================================================================

# MONGODB CONFIGURATION
# ============================================================================
# Atlas example (never commit real passwords — use Vercel/host secrets):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/timeless?retryWrites=true&w=majority
# Local: mongodb://127.0.0.1:27017  (and create DB "timeless" or set name below)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=timeless

# JWT CONFIGURATION
# ============================================================================
# Secret key for JWT signing (MUST BE AT LEAST 32 CHARACTERS)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production to a strong random string!
SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters

# JWT signing algorithm (HS256, HS384, HS512)
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MESSAGE ENCRYPTION CONFIGURATION
# ============================================================================
# AES encryption key for message encryption (MUST BE EXACTLY 32 CHARACTERS)
# For AES-256, the key must be 32 bytes (hex encoded = 64 characters, or 32 UTF-8 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# IMPORTANT: Change this in production to a strong random string!
ENCRYPTION_KEY=your-encryption-key-must-be-32-characters-for-aes256

# SERVER CONFIGURATION
# ============================================================================
# Debug mode (True for development, False for production)
# IMPORTANT: Set to False in production for security
DEBUG=True

# Server host
HOST=0.0.0.0

# Server port
PORT=8000

# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS (comma-separated)
# Example: ["http://localhost:3000", "http://localhost:8080", "https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. SECRET_KEY:
#    - Minimum 32 characters for security
#    - Use a cryptographically secure random string
#    - NEVER commit to version control
#    - Change in production
#
# 2. ENCRYPTION_KEY:
#    - Must be EXACTLY 32 characters for AES-256
#    - Use a cryptographically secure random string
#    - NEVER commit to version control
#    - Change in production
#    - Keep secure - data encrypted with this key cannot be decrypted without it
#
# 3. MONGODB_URI:
#    - Use strong passwords
#    - Atlas uses TLS by default (mongodb+srv://...)
#    - Never commit credentials to version control
#    - Consider using environment secrets in production
#
# 4. DEBUG:
#    - ALWAYS set to False in production
#    - This prevents information disclosure
#
# 5. CORS_ORIGINS:
#    - Specify exact allowed origins
#    - Be restrictive in production
#    - Use HTTPS only in production

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production:
# [ ] DEBUG=False
# [ ] Generate and set strong SECRET_KEY
# [ ] Generate and set strong ENCRYPTION_KEY
# [ ] MongoDB URI with strong password (Atlas: rotate if exposed)
# [ ] MongoDB network access (IP allowlist or Vercel integration)
# [ ] CORS_ORIGINS configured with actual domain
# [ ] All credentials stored in secure secrets manager
# [ ] Regular backups of encryption key
# [ ] Use HTTPS/TLS for all connections
# [ ] Set up monitoring and logging
# [ ] Run security audit
